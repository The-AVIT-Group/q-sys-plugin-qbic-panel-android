<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

  <!-- Network -->
  <uses-permission android:name="android.permission.INTERNET" />

  <!-- Keep screen awake / wake screen on command -->
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <!-- Auto-start after reboot -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <!-- Camera — for MJPEG stream server on port 9091.
       Grant at device setup:  adb shell pm grant au.com.theavitgroup.qbiccontrol android.permission.CAMERA -->
  <uses-permission android:name="android.permission.CAMERA" />
  <uses-feature android:name="android.hardware.camera2" android:required="false" />

  <!-- Write secure settings — to enable/disable the Android 12 camera privacy LED.
       Grant at device setup:  adb shell pm grant au.com.theavitgroup.qbiccontrol android.permission.WRITE_SECURE_SETTINGS -->
  <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />

  <!-- Allow service to launch BootActivity from background to satisfy camera foreground check -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

  <!-- Foreground service (required API 28+) -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <!-- Foreground service type declaration (required API 34+) -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />

  <!-- Show notification for the foreground service (required API 33+) -->
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

  <!-- Device admin — required for screen lock via DevicePolicyManager.lockNow().
       Activate with: adb shell dpm set-active-admin
           au.com.theavitgroup.qbiccontrol/.DeviceAdminReceiver -->
  <uses-permission android:name="android.permission.BIND_DEVICE_ADMIN" />

  <!-- Inject input events (HOME keyevent) — signature|privileged permission.
       Granted automatically because the APK lives in /system/priv-app/, but only
       after the package is listed in a privapp-permissions whitelist XML at
       /system/etc/permissions/privapp-permissions-qbiccontrol.xml. -->
  <uses-permission android:name="android.permission.INJECT_EVENTS" />

  <!-- Usage stats — to detect when the kiosk browser (com.qbic.smilplayer) is
       in the foreground. Grant at device setup:
       adb shell appops set au.com.theavitgroup.qbiccontrol PACKAGE_USAGE_STATS allow -->
  <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
    tools:ignore="ProtectedPermissions" />

  <application
    android:allowBackup="false"
    android:icon="@android:drawable/ic_dialog_info"
    android:label="@string/app_name"
    android:supportsRtl="true"
    android:theme="@style/Theme.QbicControl">

    <!-- Status activity — tap the launcher icon to see IP:port and toggle service -->
    <activity
      android:name=".MainActivity"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

    <!-- Transparent boot shim: satisfies QBIC firmware Uid mode: CAMERA: foreground
         by briefly presenting a visible Activity before finishing immediately -->
    <activity
      android:name=".BootActivity"
      android:exported="false"
      android:theme="@android:style/Theme.Translucent.NoTitleBar"
      android:excludeFromRecents="true" />

    <!-- Foreground service that hosts the WebSocket server -->
    <service
      android:name=".QbicControlService"
      android:exported="true"
      android:foregroundServiceType="connectedDevice|camera" />

    <!-- Auto-start on boot -->
    <receiver
      android:name=".BootReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
      </intent-filter>
    </receiver>

    <!-- Accessibility service — captures screen for the /screen HTTP endpoint (API 30+) -->
    <service
      android:name=".ScreenCaptureService"
      android:exported="false"
      android:label="@string/app_name"
      android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/accessibility_service_config" />
    </service>

    <!-- Device admin receiver — needed for screen lock -->
    <receiver
      android:name=".DeviceAdminReceiver"
      android:exported="true"
      android:permission="android.permission.BIND_DEVICE_ADMIN">
      <meta-data
        android:name="android.app.device_admin"
        android:resource="@xml/device_admin" />
      <intent-filter>
        <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
      </intent-filter>
    </receiver>

  </application>

</manifest>
